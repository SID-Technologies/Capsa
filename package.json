{
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:web": "cd apps/web && pnpm dev",
    "build:web": "cd apps/web && pnpm build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:links": "node scripts/check-links.mjs",
    "check:stale": "node scripts/check-stale-docs.mjs",
    "check": "node scripts/check-links.mjs && node scripts/check-stale-docs.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tamagui/config": "^1.135.2",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.10.0"
  },
  "dependencies": {
    "@tamagui/colors": "^1.135.2",
    "@tamagui/core": "^1.135.2",
    "react": "19.2.7",
    "react-dom": "19.0.0",
    "tamagui": "^1.135.2"
  }
}
