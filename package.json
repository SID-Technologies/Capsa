{
  "name": "capsa",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "predev": "node scripts/sync-openapi.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:links": "node scripts/check-links.mjs",
    "check:stale": "node scripts/check-stale-docs.mjs",
    "check": "node scripts/check-links.mjs && node scripts/check-stale-docs.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.1",
    "@fontsource/space-grotesk": "^5.1.1",
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "3.1.1",
    "@scalar/api-reference-react": "0.9.43",
    "@tabler/icons-react": "^3.28.1",
    "@tamagui/colors": "^1.135.2",
    "@tamagui/core": "^1.135.2",
    "@workos-inc/authkit-react": "^0.10.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "posthog-js": "^1.383.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.28.1",
    "rehype-highlight": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "tamagui": "^1.135.2",
    "universal-cookie": "^7.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tamagui/config": "^1.135.2",
    "@tamagui/vite-plugin": "^1.135.2",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^6.0.11",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
