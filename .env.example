# Capsa configuration. All variables are OPTIONAL — a bare deploy needs none.
# Copy to .env to use locally:  cp .env.example .env
#
# NOTE: VITE_* values are inlined into the public bundle at build time.
# Never put a secret (API key, token) in a VITE_* variable.

# ── Branding ────────────────────────────────────────────────────────────────
# Name shown in the top bar, page titles, and footer (default: "Capsa").
VITE_SITE_NAME="Capsa"
# Footer copyright name (defaults to VITE_SITE_NAME).
# VITE_SITE_ORG="Acme, Inc."

# ── Theming ─────────────────────────────────────────────────────────────────
# Pin a theme and hide the switcher: default | aurora | steel | retro | shadcn
# VITE_DEFAULT_THEME_STYLE="steel"

# ── SEO ─────────────────────────────────────────────────────────────────────
# Base URL — enables sitemap.xml and absolute URLs in llms.txt.
# VITE_SITE_URL="https://docs.example.com"

# ── Footer links (each renders only if set) ─────────────────────────────────
# VITE_GITHUB_URL="https://github.com/your-org/your-docs"
# VITE_STATUS_URL="https://status.example.com"
# VITE_SUPPORT_URL="https://example.com/support"

# ── Multi-product (optional) ────────────────────────────────────────────────
# Scope nav + search to one product folder under content/.
# VITE_PRODUCT="acme"

# ── Analytics (PostHog — off unless key is set) ─────────────────────────────
# VITE_POSTHOG_KEY="phc_xxx"
# VITE_POSTHOG_HOST="https://us.i.posthog.com"

# ── Authentication (public by default; set to opt in) ───────────────────────
# VITE_WORKOS_CLIENT_ID="client_xxx"
# VITE_PLATFORM_API_URL="https://api.example.com"
# Force public access even when auth is configured:
# VITE_DEV_BYPASS_AUTH="true"

# ── Build-time only ─────────────────────────────────────────────────────────
# Optional: copy an external OpenAPI spec into public/openapi/v1.yaml on dev.
# OPENAPI_SOURCE="../api/openapi.yaml"
